			"scriptLines": [
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> boletas",
				"source(output(",
				"          paquete_id as string,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as string,",
				"          costo_estimado_bs as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> catalogo",
				"source(output(",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> controles",
				"source(output(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as string,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as string,",
				"          fecha_proxima_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> entregas",
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> establecimientos",
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> inscripciones",
				"boletas derive(boleta_id = toInteger(boleta_id),",
				"          control_id = toInteger(control_id),",
				"          ci_numero = toInteger(regexReplace(ci_beneficiaria, '[^0-9]', '')),",
				"          ci_expedicion = upper(trim(regexReplace(ci_beneficiaria, '[0-9\\\\-]', ''))),",
				"          nro_boleta = coalesce(trim(upper(nro_boleta)), 'NO REGISTRADO'),",
				"          fecha_emision = coalesce( toDate(fecha_emision, 'yyyy-MM-dd'), toDate(fecha_emision, 'dd/MM/yyyy'), toDate(fecha_emision, 'dd-MM-yyyy'), toDate(fecha_emision, 'MM/dd/yyyy'), toDate(fecha_emision, 'yyyy/MM/dd'), toDate(fecha_emision, 'dd.MM.yyyy'), toDate(fecha_emision, 'yyyyMMdd'),  toDate('1900-01-01')  ),",
				"          estado = coalesce(trim(upper(estado)), 'NO REGISTRADO')) ~> derivedColumn1",
				"catalogo derive(paquete_id = toInteger(paquete_id),",
				"          nombre = coalesce(trim(upper(nombre)), 'NO REGISTRADO'),",
				"          contenido = coalesce(trim(upper(contenido)), 'SIN CONTENIDO'),",
				"          peso_estandar_kg = coalesce(toFloat(peso_estandar_kg), toFloat(0.0)),",
				"          costo_estimado_bs = coalesce(toFloat(costo_estimado_bs), toFloat(0.0))) ~> derivedColumn2",
				"controles derive(control_id = toInteger(control_id),",
				"          ci_numero = toInteger(regexReplace(ci_beneficiaria, '[^0-9]', '')),",
				"          ci_expedicion = upper(trim(regexReplace(ci_beneficiaria, '[0-9\\\\-]', ''))),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          nro_control = toInteger(nro_control),",
				"          fecha_control = coalesce(     toDate(fecha_control, 'yyyy-MM-dd'),      toDate(fecha_control, 'dd/MM/yyyy'),      toDate(fecha_control, 'dd-MM-yyyy'),      toDate(fecha_control, 'MM/dd/yyyy'),      toDate(fecha_control, 'yyyy/MM/dd'),      toDate(fecha_control, 'dd.MM.yyyy'),      toDate(fecha_control, 'yyyyMMdd'),        toDate('1900-01-01')                  ),",
				"          semana_gestacion = coalesce(toInteger(semana_gestacion), toInteger(0)),",
				"          peso_madre_kg = coalesce(toFloat(peso_madre_kg), toFloat(0.0)),",
				"          presion_arterial = coalesce(trim(presion_arterial), 'NO REGISTRADO')) ~> derivedColumn3",
				"entregas derive(entrega_id = toInteger(entrega_id),",
				"          boleta_id = toInteger(boleta_id),",
				"          ci_numero = toInteger(regexReplace(ci_beneficiaria, '[^0-9]', '')),",
				"          ci_expedicion = upper(trim(regexReplace(ci_beneficiaria, '[0-9\\\\-]', ''))),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          paquete_id = toInteger(paquete_id),",
				"          paquete_nombre = coalesce(trim(upper(paquete_nombre)), 'NO REGISTRADO'),",
				"          fecha_entrega = coalesce(     toDate(fecha_entrega, 'yyyy-MM-dd'), toDate(fecha_entrega, 'dd/MM/yyyy'),      toDate(fecha_entrega, 'dd-MM-yyyy'), toDate(fecha_entrega, 'MM/dd/yyyy'),      toDate(fecha_entrega, 'yyyy/MM/dd'), toDate(fecha_entrega, 'dd.MM.yyyy'),      toDate(fecha_entrega, 'yyyyMMdd'), toDate('1900-01-01')                  ),",
				"          lote_produccion = iif(isNull(lote_produccion) || equals(trim(lote_produccion), ''), 'SIN LOTE', trim(upper(lote_produccion))),",
				"          peso_paquete_kg = coalesce(toFloat(peso_paquete_kg), toFloat(0.0)),",
				"          fecha_proxima_entrega = coalesce(     toDate(fecha_proxima_entrega, 'yyyy-MM-dd'), toDate(fecha_proxima_entrega, 'dd/MM/yyyy'),      toDate(fecha_proxima_entrega, 'dd-MM-yyyy'), toDate(fecha_proxima_entrega, 'MM/dd/yyyy'),      toDate(fecha_proxima_entrega, 'yyyy/MM/dd'), toDate(fecha_proxima_entrega, 'dd.MM.yyyy'),      toDate(fecha_proxima_entrega, 'yyyyMMdd'), toDate('1900-01-01')                  )) ~> derivedColumn4",
				"establecimientos derive(establecimiento_id = toInteger(establecimiento_id),",
				"          codigo_snis = coalesce(trim(upper(codigo_snis)), 'SIN CODIGO'),",
				"          nombre = coalesce(trim(upper(nombre)), 'NO REGISTRADO'),",
				"          tipo = coalesce(trim(upper(tipo)), 'NO REGISTRADO'),",
				"          nivel_atencion = coalesce(trim(upper(nivel_atencion)), 'NO REGISTRADO'),",
				"          municipio = coalesce(trim(upper(municipio)), 'NO REGISTRADO'),",
				"          departamento = case(     isNull(departamento) || equals(trim(departamento), ''), 'NO REGISTRADO',     rlike(upper(departamento), '.*(PAZ|LP).*'), 'LP',     rlike(upper(departamento), '.*(COCHABAMBA|CBBA|CBB|CB).*'), 'CB',     rlike(upper(departamento), '.*(SANTA CRUZ|CRUZ|SCZ|SC).*'), 'SC',     rlike(upper(departamento), '.*(ORURO|OR).*'), 'OR',     rlike(upper(departamento), '.*(POTOS|PT).*'), 'PT',     rlike(upper(departamento), '.*(CHUQUISACA|CHU|CH).*'), 'CH',     rlike(upper(departamento), '.*(TARIJA|TJ).*'), 'TJ',     rlike(upper(departamento), '.*(BENI|BN).*'), 'BN',     rlike(upper(departamento), '.*(PANDO|PD|PA).*'), 'PD',     upper(trim(departamento)) ),",
				"          red_salud = coalesce(trim(upper(red_salud)), 'NO REGISTRADO'),",
				"          estado = coalesce(trim(upper(estado)), 'NO REGISTRADO')) ~> derivedColumn5",
				"inscripciones derive(inscripcion_id = toInteger(inscripcion_id),",
				"          ci_numero = toInteger(regexReplace(ci_beneficiaria, '[^0-9]', '')),",
				"          ci_expedicion = upper(trim(regexReplace(ci_beneficiaria, '[0-9\\\\-]', ''))),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          fecha_inscripcion = coalesce(\r",
				"toDate(fecha_inscripcion, 'yyyy-MM-dd'),\r",
				"toDate(fecha_inscripcion, 'dd/MM/yyyy'),\r",
				"toDate(fecha_inscripcion, 'dd-MM-yyyy'),\r",
				"toDate(fecha_inscripcion, 'MM/dd/yyyy'),\r",
				"toDate(fecha_inscripcion, 'yyyy/MM/dd'),\r",
				"toDate(fecha_inscripcion, 'dd.MM.yyyy'),\r",
				"toDate(fecha_inscripcion, 'yyyyMMdd'),\r",
				"\r",
				"toDate('1900-01-01')\r",
				"\r",
				"),",
				"          semana_gestacion = coalesce(toInteger(semana_gestacion), toInteger(0)),",
				"          estado = coalesce(trim(upper(estado)), 'NO REGISTRADO')) ~> derivedColumn6",
				"derivedColumn1 select(mapColumn(",
