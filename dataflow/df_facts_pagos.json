{
	"name": "df_facts_pagos",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_pagos_bja",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_facts_pagos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          pago_id as integer,",
				"          ci_numero as integer,",
				"          ci_expedicion as string,",
				"          concepto_pago as string,",
				"          monto_bs as double,",
				"          fecha_pago as date,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(fecha_id = toInteger(toString(fecha_pago, 'yyyyMMdd'))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          pago_id,",
				"          ci_numero,",
				"          ci_expedicion,",
				"          concepto_pago,",
				"          monto_bs,",
				"          estado_pago,",
				"          fecha_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          pago_id as integer,",
				"          fecha_id as integer,",
				"          ci_numero as integer,",
				"          ci_expedicion as string,",
				"          concepto_pago as string,",
				"          monto_bs as double,",
				"          estado_pago as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}