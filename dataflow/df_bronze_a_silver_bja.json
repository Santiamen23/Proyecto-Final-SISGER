			"scriptLines": [
				"source(output(",
				"          control_prenatal_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> controlesprenatales",
				"source(output(",
				"          control_pediatrico_id as string,",
				"          ci_nino as string,",
				"          ci_madre as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          peso_nino_kg as string,",
				"          talla_nino_cm as string,",
				"          vacuna_aplicada as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> controlespediatricos",
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> establecimientossalud",
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> inscripciones",
				"source(output(",
				"          pago_id as string,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as string,",
				"          fecha_pago as string,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> pagos",
				"source(output(",
				"          parto_id as string,",
				"          ci_madre as string,",
				"          ci_recien_nacido as string,",
				"          establecimiento_id as string,",
				"          fecha_parto as string,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as string,",
				"          talla_nacimiento_cm as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> partos",
				"controlesprenatales derive(control_prenatal_id = toInteger(control_prenatal_id),",
				"          ci_numero = toInteger(regexReplace(ci_beneficiaria, '[^0-9]', '')),",
				"          ci_expedicion = upper(trim(regexReplace(ci_beneficiaria, '[0-9\\\\-]', ''))),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          nro_control = toInteger(nro_control),",
				"          fecha_control = coalesce(     toDate(fecha_control, 'yyyy-MM-dd'),      toDate(fecha_control, 'dd/MM/yyyy'),      toDate(fecha_control, 'dd-MM-yyyy'),      toDate(fecha_control, 'MM/dd/yyyy'),      toDate(fecha_control, 'yyyy/MM/dd'),      toDate(fecha_control, 'dd.MM.yyyy'),      toDate(fecha_control, 'yyyyMMdd'),        toDate('1900-01-01')                  ),",
				"          semana_gestacion = iif(isNull(semana_gestacion), toInteger(0), toInteger(semana_gestacion)),",
				"          peso_madre_kg = iif(isNull(peso_madre_kg), toFloat(0.0), toFloat(peso_madre_kg)),",
				"          presion_arterial = iif(isNull(presion_arterial), 'NO REGISTRADO', trim(presion_arterial)),",
				"          resultado = case(\r",
				"    isNull(resultado) || equals(trim(resultado), ''), 'NO REGISTRADO',\r",
				"    rlike(upper(resultado), '.*(NORM|NORAM|NOMR|NORMA|NRMAL|NORRMAL|NORRMAAL).*'), 'NORMAL',\r",
				"    rlike(upper(resultado), '.*(ALTO|GRAVE).*'), 'RIESGO ALTO',\r",
				"    rlike(upper(resultado), '.*(MOD|MEDIO).*'), 'RIESGO MODERADO',\r",
				"    rlike(upper(resultado), '.*(BAJO|LEVE).*'), 'RIESGO BAJO',\r",
				"    rlike(upper(resultado), '.*(RIESG|RIIESG).*'), 'RIESGO NO ESPECIFICADO',\r",
				"    upper(trim(resultado))\r",
				")) ~> derivedColumn1",
				"controlespediatricos derive(control_pediatrico_id = toInteger(control_pediatrico_id),",
				"          ci_numero_nino = toInteger(regexReplace(ci_nino, '[^0-9]', '')),",
				"          ci_expedicion_nino = upper(trim(regexReplace(ci_nino, '[0-9\\\\-]', ''))),",
				"          ci_numero_madre = toInteger(regexReplace(ci_madre, '[^0-9]', '')),",
				"          ci_expedicion_madre = upper(trim(regexReplace(ci_madre, '[0-9\\\\-]', ''))),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          nro_control = toInteger(nro_control),",
				"          fecha_control = coalesce(     toDate(fecha_control, 'yyyy-MM-dd'),      toDate(fecha_control, 'dd/MM/yyyy'),      toDate(fecha_control, 'dd-MM-yyyy'),      toDate(fecha_control, 'MM/dd/yyyy'),      toDate(fecha_control, 'yyyy/MM/dd'),      toDate(fecha_control, 'dd.MM.yyyy'),      toDate(fecha_control, 'yyyyMMdd'),        toDate('1900-01-01')                  ),",
				"          peso_nino_kg = coalesce(toFloat(peso_nino_kg), toFloat(0.0)),",
				"          talla_nino_cm = coalesce(toFloat(talla_nino_cm), toFloat(0.0)),",
				"          vacuna_aplicada = coalesce(trim(upper(vacuna_aplicada)), 'NO REGISTRADA'),",
				"          resultado = case(     isNull(resultado) || equals(trim(resultado), ''), 'NO REGISTRADO',     \r",
				"rlike(upper(resultado), '.*(NORM|NORAM|NOMR|NRMAL|NOORMA|NORRMAL).*'), 'NORMAL',    \r",
				" rlike(upper(resultado), '.*(BAJO|MENOR).*'), 'BAJO PESO',     \r",
				" rlike(upper(resultado), '.*(DESNUTRI|DESN).*'), 'DESNUTRICION',     \r",
				" rlike(upper(resultado), '.*(SOBRE|ALTO|MAYOR).*'), 'SOBREPESO',    \r",
				"  upper(trim(resultado)) )) ~> derivedColumn2",
				"establecimientossalud derive(establecimiento_id = toInteger(establecimiento_id),",
				"          codigo_snis = coalesce(trim(upper(codigo_snis)), 'SIN CODIGO'),",
				"          nombre = coalesce(trim(upper(nombre)), 'NO REGISTRADO'),",
				"          tipo = coalesce(trim(upper(tipo)), 'NO REGISTRADO'),",
				"          nivel_atencion = coalesce(trim(upper(nivel_atencion)), 'NO REGISTRADO'),",
				"          municipio = coalesce(trim(upper(municipio)), 'NO REGISTRADO'),",
				"          departamento = case(     isNull(departamento) || equals(trim(departamento), ''), 'NO REGISTRADO',     rlike(upper(departamento), '.*(PAZ).*'), 'LP',     rlike(upper(departamento), '.*(COCHABAMBA|CBBA|CBB).*'), 'CB',     rlike(upper(departamento), '.*(SANTA CRUZ|CRUZ|SCZ).*'), 'SC',     rlike(upper(departamento), '.*(ORURO).*'), 'OR',     rlike(upper(departamento), '.*(POTOS).*'), 'PT',     rlike(upper(departamento), '.*(CHUQUISACA|CHU).*'), 'CH',     rlike(upper(departamento), '.*(TARIJA).*'), 'TJ',     rlike(upper(departamento), '.*(BENI).*'), 'BN',     rlike(upper(departamento), '.*(PANDO).*'), 'PA',     upper(trim(departamento)) ),",
				"          red_salud = coalesce(trim(upper(red_salud)), 'NO REGISTRADO'),",
				"          estado = coalesce(trim(upper(estado)), 'NO REGISTRADO')) ~> derivedColumn3",
				"inscripciones derive(inscripcion_id = toInteger(inscripcion_id),",
				"          ci_numero = toInteger(regexReplace(ci_beneficiaria, '[^0-9]', '')),",
				"          ci_expedicion = upper(trim(regexReplace(ci_beneficiaria, '[0-9\\\\-]', ''))),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          fecha_inscripcion = coalesce(     \r",
				"toDate(fecha_inscripcion, 'yyyy-MM-dd'),      \r",
				"toDate(fecha_inscripcion, 'dd/MM/yyyy'),      \r",
				"toDate(fecha_inscripcion, 'dd-MM-yyyy'),      \r",
				"toDate(fecha_inscripcion, 'MM/dd/yyyy'),      \r",
				"toDate(fecha_inscripcion, 'yyyy/MM/dd'),      \r",
				"toDate(fecha_inscripcion, 'dd.MM.yyyy'),     \r",
				"toDate(fecha_inscripcion, 'yyyyMMdd'),       \r",
				"toDate('1900-01-01')   ),",
				"          semana_gestacion = coalesce(toInteger(semana_gestacion), toInteger(0)),",
				"          estado = coalesce(trim(upper(estado)), 'NO REGISTRADO')) ~> derivedColumn4",
				"pagos derive(pago_id = toInteger(pago_id),",
				"          ci_numero = toInteger(regexReplace(ci_beneficiaria, '[^0-9]', '')),",
				"          ci_expedicion = upper(trim(regexReplace(ci_beneficiaria, '[0-9\\\\-]', ''))),",
				"          concepto_pago = coalesce(trim(upper(concepto_pago)), 'NO REGISTRADO'),",
				"          monto_bs = coalesce(toFloat(monto_bs), toFloat(0.0)),",
				"          fecha_pago = coalesce(     toDate(fecha_pago, 'yyyy-MM-dd'),      toDate(fecha_pago, 'dd/MM/yyyy'),      toDate(fecha_pago, 'dd-MM-yyyy'),      toDate(fecha_pago, 'MM/dd/yyyy'),      toDate(fecha_pago, 'yyyy/MM/dd'),      toDate(fecha_pago, 'dd.MM.yyyy'),      toDate(fecha_pago, 'yyyyMMdd'),        toDate('1900-01-01')                  ),",
				"          estado_pago = coalesce(trim(upper(estado_pago)), 'NO REGISTRADO'),",
				"          canal_pago = coalesce(trim(upper(canal_pago)), 'NO REGISTRADO'),",
				"          nro_comprobante = coalesce(trim(upper(nro_comprobante)), 'SIN COMPROBANTE')) ~> derivedColumn5",
				"partos derive(parto_id = toInteger(parto_id),",
				"          ci_madre_numero = toInteger(regexReplace(ci_madre, '[^0-9]', '')),",
				"          ci_madre_expedicion = upper(trim(regexReplace(ci_madre, '[0-9\\\\-]', ''))),",
				"          ci_recien_nacido_numero = toInteger(regexReplace(ci_recien_nacido, '[^0-9]', '')),",
				"          ci_recien_nacido_expedicion = upper(trim(regexReplace(ci_recien_nacido, '[0-9\\\\-]', ''))),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          fecha_parto = coalesce(     toDate(fecha_parto, 'yyyy-MM-dd'), toDate(fecha_parto, 'dd/MM/yyyy'),      toDate(fecha_parto, 'dd-MM-yyyy'), toDate(fecha_parto, 'MM/dd/yyyy'),      toDate(fecha_parto, 'yyyy/MM/dd'), toDate(fecha_parto, 'dd.MM.yyyy'),      toDate(fecha_parto, 'yyyyMMdd'), toDate('1900-01-01')                  ),",
				"          tipo_parto = case(     isNull(tipo_parto) || equals(trim(tipo_parto), ''), 'NO REGISTRADO',     rlike(upper(tipo_parto), '.*(CES).*'), 'CESAREA',     rlike(upper(tipo_parto), '.*(NAT|NOR|NR|NT).*'), 'NATURAL',     upper(trim(tipo_parto)) ),",
				"          peso_nacimiento_kg = coalesce(toFloat(peso_nacimiento_kg), toFloat(0.0)),",
				"          talla_nacimiento_cm = coalesce(toFloat(talla_nacimiento_cm), toFloat(0.0))) ~> derivedColumn6",
				"derivedColumn1 select(mapColumn(",
				"          control_prenatal_id,",
				"          ci_numero,",
				"          ci_expedicion,",
				"          establecimiento_id,",
				"          nro_control,",
				"          fecha_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial,",
				"          resultado",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn2 select(mapColumn(",
				"          control_pediatrico_id,",
				"          ci_numero_nino,",
				"          ci_expedicion_nino,",
				"          ci_numero_madre,",
				"          ci_expedicion_madre,",
				"          establecimiento_id,",
				"          nro_control,",
				"          fecha_control,",
				"          peso_nino_kg,",
				"          talla_nino_cm,",
				"          vacuna_aplicada,",
				"          resultado",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"derivedColumn4 select(mapColumn(",
				"          inscripcion_id,",
				"          ci_numero,",
				"          ci_expedicion,",
				"          establecimiento_id,",
				"          fecha_inscripcion,",
				"          semana_gestacion,",
				"          estado",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"derivedColumn5 select(mapColumn(",
				"          pago_id,",
				"          ci_numero,",
				"          ci_expedicion,",
				"          concepto_pago,",
				"          monto_bs,",
				"          fecha_pago,",
				"          estado_pago,",
				"          canal_pago,",
				"          nro_comprobante",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"derivedColumn6 select(mapColumn(",
				"          parto_id,",
				"          ci_madre_numero,",
				"          ci_madre_expedicion,",
				"          ci_recien_nacido_numero,",
				"          ci_recien_nacido_expedicion,",
				"          establecimiento_id,",
				"          fecha_parto,",
				"          tipo_parto,",
				"          peso_nacimiento_kg,",
				"          talla_nacimiento_cm",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_prenatal_id as integer,",
				"          ci_numero as integer,",
				"          ci_expedicion as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as double,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          control_prenatal_id,",
				"          ci_numero,",
				"          ci_expedicion,",
				"          establecimiento_id,",
				"          nro_control,",
				"          fecha_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial,",
				"          resultado",
				"     )) ~> sink1",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_pediatrico_id as integer,",
				"          ci_nino_numero as integer,",
				"          ci_nino_expedicion as string,",
				"          ci_madre_numero as integer,",
				"          ci_madre_expedicion as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          peso_nino_kg as double,",
