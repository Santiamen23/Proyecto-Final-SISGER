				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          control_pediatrico_id,",
				"          ci_nino_numero = ci_numero_nino,",
				"          ci_nino_expedicion = ci_expedicion_nino,",
				"          ci_madre_numero = ci_numero_madre,",
